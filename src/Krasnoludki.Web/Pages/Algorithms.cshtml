@page
@model AlgorithmsModel
@{
  ViewData["Title"] = "Algorytmy | Królewski System Zarządzania Królestwem";
}

<header>
  <div class="container" style="display: flex; justify-content: space-between; align-items: center;">
    <div style="display: flex; gap: 36px;">
      <a asp-page="/Index" class="logo">K.S.Z.K</a>

      <nav>
        <a asp-page="/Map" class="nav-button">Mapa</a>
        <a asp-page="/Algorithms" class="nav-button active">Algorytmy</a>
        <a asp-page="/Book" class="nav-button">Księga</a>
      </nav>
    </div>

    <div>
      <span>@Model.ActiveScenarioName</span>
    </div>
  </div>
</header>

@if (Model.SelectedScenarioId == null)
{
  <div class="container" style="margin-top: 32px; text-align: center;">
    <h2 style="margin-bottom: 32px;">Wybierz scenariusz, aby zobaczyć dostępne algorytmy</h2>
  </div>
}
else
{

  <section class="container main-view">
    <main>
      <canvas id="algoCanvas" width="1500" height="1000"></canvas>
    </main>

    <aside class="algo-aside">
      <div class="aside-item">
        <div class="field-y" style="align-items: flex-start; padding: 0 16px; margin-bottom: 16px;">
          <span style="font-size: 1.2rem;">Algorytmy</span>
          <small>Wybierz algorytm</small>
        </div>

        @if (Model.Algorithm != null)
        {
          <div style="padding: 0 16px; margin-bottom: 16px;">
            <button onClick="runAlgorithm('@(Model.Algorithm ?? "")')" id="algo-run-button">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" style="height: 20px; width: 20px;">
                <g class="" style="" transform="translate(0,0)">
                  <path
                  d="M106.854 106.002a26.003 26.003 0 0 0-25.64 29.326c16 124 16 117.344 0 241.344a26.003 26.003 0 0 0 35.776 27.332l298-124a26.003 26.003 0 0 0 0-48.008l-298-124a26.003 26.003 0 0 0-10.136-1.994z"
                  fill="#fff" fill-opacity="1" />
                </g>
              </svg>
              Uruchom
            </button>
          </div>
        }

        <a asp-page="/Algorithms" asp-route-algorithm="matching"
           class="algo-button@(Model.Algorithm == "matching" ? " active" : "")" data-tool="algo1"><span>Przydział do
          Kopalni</span>
          @* @if (Model.HasMatchingResult)
          {
            <p class="status active">Uruchomiono</p>
          }
          else
          {
            <p class="status">Nie uruchomiono</p>
          } *@
        </a>
        <a asp-page="/Algorithms" asp-route-algorithm="minCost"
           class="algo-button@(Model.Algorithm == "minCost" ? " active" : "")" data-tool="algo2"><span>Optymalizacja z
          Owsianką</span>
          @* @if (Model.HasMinCostResult)
          {
            <p class="status active">Uruchomiono</p>
          }
          else
          {
            <p class="status">Nie uruchomiono</p>
          } *@
        </a>
        <a asp-page="/Algorithms" asp-route-algorithm="convexHull"
           class="algo-button@(Model.Algorithm == "convexHull" ? " active" : "")" data-tool="algo3"><span>Wyznaczenie
          granicy Królestwa</span>
          @if (Model.HasConvexHullResult)
          {
            <p class="status active">Uruchomiono</p>
          }
          else
          {
            <p class="status">Nie uruchomiono</p>
          }
        </a>
        <a asp-page="/Algorithms" asp-route-algorithm="rmq"
           class="algo-button@(Model.Algorithm == "rmq" ? " active" : "")" data-tool="algo4"><span>Najgłośniejszy
          dekamentrysta</span>
          @* @if (Model.HasRmqResult)
          {
            <p class="status active">Uruchomiono</p>
          }
          else
          {
            <p class="status">Nie uruchomiono</p>
          } *@
        </a>

      </div>

      <div class="algo-aside-actions">
      </div>
    </aside>
  </section>

}


@* <canvas id="mapCanvas" width="1500" height="1000"></canvas> *@


@section Scripts {
  <script>
    const INITIAL_NODES = @Html.Raw(Model.NodesJson);
    const ALGORITHM_RESULTS = @Html.Raw(Model.ResultsJson);
  </script>
  <script src="~/js/map/state.js" asp-append-version="true"></script>
  <script src="~/js/services/api-service.js" asp-append-version="true"></script>
  <script src="~/js/algorithms/algo-visualizer.js" asp-append-version="true"></script>
}