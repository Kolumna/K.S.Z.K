@page
@model IndexModel
@{
  ViewData["Title"] = "Algorytmy | Królewski System Zarządzania Królestwem";
}

<header>
  <div class="container" style="display: flex; justify-content: space-between; align-items: center;">
    <div style="display: flex; gap: 36px;">
      <a asp-page="/Index" class="logo">K.S.Z.K</a>

      <nav>
        <a asp-page="/Map" class="nav-button">Mapa</a>
        <a asp-page="/Algorithms" class="nav-button active">Algorytmy</a>
        <a asp-page="/Index" class="nav-button">Księga</a>
      </nav>
    </div>

    <div>
      <span>Nowa mapa</span>
    </div>
  </div>
</header>

<section class="container main-view">
  <main>
    <canvas id="mapCanvas" width="1500" height="1000"></canvas>
  </main>

  <aside class="algo-aside">
    <div class="aside-item">
      <div class="field-y" style="align-items: flex-start; padding: 0 16px;">
        <span style="font-size: 1.2rem;">Algorytmy</span>
        <small>Wybierz algorytm</small>

      </div>

     
      <div class="algo-buttons-group">
        <button class="algo-button active" data-tool="algo1"><span>Algorytm 1</span><small>
          Rozmieść krasnoludki optymalnie, by wydobywały jak najwięcej surowców!
        </small>
        <p class="status">Uruchiomiono</p>
      </button>
      <button class="algo-button" data-tool="algo2"><span>Algorytm 2</span>
        <p class="status">Nie uruchiomiono</p>
      </button>
      <button class="algo-button" data-tool="algo3"><span>Algorytm 3</span>
        <p class="status">Nie uruchiomiono</p>
      </button>
      <button class="algo-button" data-tool="algo4"><span>Algorytm 4</span>
        <p class="status">Nie uruchiomiono</p>
      </button>
      <button class="algo-button" data-tool="algo4"><span>Algorytm 4</span>
        <p class="status">Nie uruchiomiono</p>
      </button>
    </div>
  </div>

  <div class="algo-aside-actions">
  </div>
</aside>
</section>


@* <canvas id="mapCanvas" width="1500" height="1000"></canvas> *@


@section Scripts {
  <script src="~/js/map-editor.js" asp-append-version="true"></script>

  <script>
    console.log("Królewski kartograf gotowy do pracy!");
