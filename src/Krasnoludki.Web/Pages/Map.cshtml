@page
@model IndexModel
@{
  ViewData["Title"] = "Mapa | Królewski System Zarządzania Królestwem";
}

<header>
  <div class="container">
    <div style="display: flex; gap: 36px;">
      <a asp-page="/Index" class="logo">K.S.Z.K</a>

      <nav>
        <a asp-page="/Index" class="nav-button active">Mapa</a>
        <a asp-page="/Index" class="nav-button">Księga</a>
      </nav>
    </div>
  </div>
</header>

