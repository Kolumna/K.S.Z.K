<!DOCTYPE html>
<html lang="pl">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Krasnoludki.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Krasnoludki.Web.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <a class="logo" asp-page="/Index">
            <h1>K.S.Z.K</h1>
        </a>
        <p style="font-size: 2rem;">
            Królewski System Zarządzania Królestwem
        </p>
    </header>

    <main class="container" role="main">
        @RenderBody()
    </main>

    <footer>
        <p>Projekt zaliczeniowy na przedmiot: Algorytmy i Struktury Danych II</p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
